# App
PORT=3000
APP_PORT=8000
DISABLE_DOCS=0
REDIS_URL=redis://localhost:6379/0

# Feature flags
ENABLE_FEED=1
ENABLE_PREVIEWS=1
ENABLE_RATE_LIMIT=0
RATE_LIMIT_RPM=120

# Performance modes
# CACHE_MODE: off | normal | aggressive
CACHE_MODE=normal
# PARSER_MODE: full | simplified
PARSER_MODE=full

# GHCR deployment (docker-compose.ghcr.yml)
APP_IMAGE=ghcr.io/koval01/telegram-me:latest
